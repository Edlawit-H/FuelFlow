{
  "info": {
    "name": "FuelFlow API",
    "description": "Complete Postman collection for the FuelFlow Smart Fuel Station Queue Management API.\n\n## Setup\n1. Import this collection into Postman.\n2. Create an environment with the variable `baseUrl` = `http://localhost:5000/api/v1`.\n3. After calling **Register** or **Login**, copy the `token` from the response and set it as the `jwt` environment variable. All subsequent protected requests use `{{jwt}}` automatically via the Authorization header.\n4. After creating a station, set `stationId` in your environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "jwt", "value": "", "type": "string" },
    { "key": "stationId", "value": "", "type": "string" },
    { "key": "fuelType", "value": "petrol", "type": "string" },
    { "key": "entryId", "value": "", "type": "string" },
    { "key": "pinCode", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:5000/health", "host": ["localhost"], "port": "5000", "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.environment.set('userId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+10000000001\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+10000000002\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register-admin", "host": ["{{baseUrl}}"], "path": ["auth", "register-admin"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.environment.set('jwt', pm.response.json().token);",
                  "  console.log('JWT saved to environment');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+10000000001\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Delete My Account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Stations",
      "item": [
        {
          "name": "Create Station (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.environment.set('stationId', pm.response.json()._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Shell Midtown\",\n  \"address\": \"123 Main St\",\n  \"location\": {\n    \"type\": \"Point\",\n    \"coordinates\": [-73.9857, 40.7484]\n  },\n  \"fuelTypes\": [\"petrol\", \"diesel\"]\n}"
            },
            "url": { "raw": "{{baseUrl}}/stations", "host": ["{{baseUrl}}"], "path": ["stations"] }
          }
        },
        {
          "name": "List Stations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/stations?lat=40.7484&lng=-73.9857&radius_km=10",
              "host": ["{{baseUrl}}"],
              "path": ["stations"],
              "query": [
                { "key": "lat", "value": "40.7484" },
                { "key": "lng", "value": "-73.9857" },
                { "key": "radius_km", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Station by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": { "raw": "{{baseUrl}}/stations/{{stationId}}", "host": ["{{baseUrl}}"], "path": ["stations", "{{stationId}}"] }
          }
        },
        {
          "name": "Update Station (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Shell Midtown — Updated\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/stations/{{stationId}}", "host": ["{{baseUrl}}"], "path": ["stations", "{{stationId}}"] }
          }
        },
        {
          "name": "Get Recommendations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/stations/recommendations?lat=40.7484&lng=-73.9857&fuelType=petrol",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "recommendations"],
              "query": [
                { "key": "lat", "value": "40.7484" },
                { "key": "lng", "value": "-73.9857" },
                { "key": "fuelType", "value": "petrol" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Queue — User",
      "item": [
        
        {
          "name": "Join Queue",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var body = pm.response.json();",
                  "  pm.environment.set('entryId', body.entry._id);",
                  "  pm.environment.set('pinCode', body.token.pinCode);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/stations/{{stationId}}/queues/{{fuelType}}/join",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "{{stationId}}", "queues", "{{fuelType}}", "join"]
            }
          }
        },
        {
          "name": "Get My Queue Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": { "raw": "{{baseUrl}}/queue/my-status", "host": ["{{baseUrl}}"], "path": ["queue", "my-status"] }
          }
        },
        {
          "name": "Leave Queue",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/stations/{{stationId}}/queues/{{fuelType}}/leave",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "{{stationId}}", "queues", "{{fuelType}}", "leave"]
            }
          }
        }
      ]
    },
    {
      "name": "Queue — Admin",
      "item": [
        {
          "name": "List Queue Entries",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/stations/{{stationId}}/queues/{{fuelType}}",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "{{stationId}}", "queues", "{{fuelType}}"]
            }
          }
        },
        {
          "name": "Pause Queue",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/stations/{{stationId}}/queues/{{fuelType}}/pause",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "{{stationId}}", "queues", "{{fuelType}}", "pause"]
            }
          }
        },
        {
          "name": "Resume Queue",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/stations/{{stationId}}/queues/{{fuelType}}/resume",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "{{stationId}}", "queues", "{{fuelType}}", "resume"]
            }
          }
        },
        {
          "name": "Set Fuel Availability",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fuelAvailable\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/stations/{{stationId}}/queues/{{fuelType}}/availability",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "{{stationId}}", "queues", "{{fuelType}}", "availability"]
            }
          }
        },
        {
          "name": "Set Serve Time",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
                
              "mode": "raw",
              "raw": "{\n  \"serveTimeMinutes\": 8\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/stations/{{stationId}}/queues/{{fuelType}}/serve-time",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "{{stationId}}", "queues", "{{fuelType}}", "serve-time"]
            }
          }
        },
        {
          "name": "Serve User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/stations/{{stationId}}/queues/{{fuelType}}/entries/{{entryId}}/serve",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "{{stationId}}", "queues", "{{fuelType}}", "entries", "{{entryId}}", "serve"]
            }
          }
        },
        {
          "name": "Remove No-Show",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/stations/{{stationId}}/queues/{{fuelType}}/entries/{{entryId}}/no-show",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "{{stationId}}", "queues", "{{fuelType}}", "entries", "{{entryId}}", "no-show"]
            }
          }
        }
      ]
    },
    {
      "name": "Tokens",
      "item": [
        {
          "name": "Validate Token (PIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pinCode\": \"{{pinCode}}\",\n  \"stationId\": \"{{stationId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/tokens/validate", "host": ["{{baseUrl}}"], "path": ["tokens", "validate"] }
          }
        }
      ]
    }
  ]
}